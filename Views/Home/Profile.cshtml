@{
    ViewData["Title"] = "profile";
}
<style>
    .NavBar {
        background: rgba(255, 255, 255, 0.9) !important; /* ทำให้ทึบขึ้นจนมองเห็นชัด */
        backdrop-filter: none !important;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1) !important;
    }
    
    .Logo, .TLogo {
        color: #333 !important;
    }
</style>
<div class="My_profile">
    <div class="frame_1349">
            <div class="profile-card text-center shadow">
                <div id="frame_photo_text">
                    <div id="frame_photo">
                        <img src="https://img.freepik.com/free-photo/beautiful-tropical-beach-sea-with-coconut-palm-tree_74190-6843.jpg?semt=ais_user_personalization&w=740&q=80" class="rounded-circle profile-img" alt="Profile">
                    </div>
                    <div id="frame_text">
                        <h2 class="text_name">Dearja</h2>
                        <p class="text-secondary text-uppercase letter-spacing">Man , Age 96</p>
                    </div>
                </div>
            </div>
            <div class ="frame_1677">
                <div class="box_aboutme">
                    <h1 class="header_abountme">
                        <span class="font_alex">A </span>BOUT ME
                    </h1>
                </div>
                <div class="box_paragraph">
                    <p class="paragraph_abountme">
                        Lorem ipsum dolor, sit amet consectetur adipisicing elit. 
                        Illo sit omnis nemo eum tempore enim ab quibusdam cumque ad eaque 
                        facilis quam accusamus minus repellendus et provident, in aperiam soluta!
                    </p>
                </div>
                <div class="box_tag">
                    <h1 class="tag">TAG</h1>
                    <div class="frame_tag_editer">
                        <div class="box_element_tag">
                            <div class="tag_item">
                                <span class="tag_icon">🏕️</span>
                                <span class="tag_text">CAMPING</span>
                                <button type="button" class="btn_close_tag">×</button>
                            </div>

                            <div class="tag_item">
                                <span class="tag_icon">📷</span>
                                <span class="tag_text">PHOTOGRAPHY</span>
                                <button type="button" class="btn_close_tag">×</button>
                            </div>

                            <div class="tag_item">
                                <span class="tag_icon">🎒</span>
                                <span class="tag_text">BACKPACKER</span>
                                <button type="button" class="btn_close_tag">×</button>
                            </div>
                        </div>
                        <div class="btn_edit_tag">
                            <button type="button">
                                <img src="~/images/Icon.png" class="edit-icon-img" alt="edit Icon">
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
