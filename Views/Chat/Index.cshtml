        <div id="chat-room">
            <div id="chat-room-header">
                    <svg id="mobile-back-btn" onclick="closeChatRoomMobile()" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                    <h4 id="chat-room-title" class="text-sm font-semibold"></h4>
                    <img id="chat-room-setting-icon" src="~/images/setting_icon.svg" onclick="openSettingChatRoom()"/>
                </div>

            <div id="chat-body">
                </div>

            <div class="message-box">
                <div class="input-actions">
                        <input type="file" id="image-input" accept="image/*" style="display: none;" onchange="showPreviewText()" />
                        <input type="file" id="document-input" accept=".pdf,.doc,.docx,.xls,.xlsx,.zip,.txt" style="display: none;" onchange="showPreviewText()" />
                        <svg class="action-icon" alt="add file" onclick="document.getElementById('document-input').click();" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-plus-icon lucide-file-plus"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M9 15h6"/><path d="M12 18v-6"/></svg>
                        <svg class="action-icon" alt="add photo" onclick="document.getElementById('image-input').click();" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image-plus-icon lucide-image-plus"><path d="M16 5h6"/><path d="M19 2v6"/><path d="M21 11.5V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7.5"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/><circle cx="9" cy="9" r="2"/></svg>
                        <svg class="action-icon" alt="add photo" onclick="openWebRTC()" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-camera-icon lucide-camera"><path d="M13.997 4a2 2 0 0 1 1.76 1.05l.486.9A2 2 0 0 0 18.003 7H20a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h1.997a2 2 0 0 0 1.759-1.048l.489-.904A2 2 0 0 1 10.004 4z"/><circle cx="12" cy="13" r="3"/></svg>
                    </div>
                <div id="file-name-display" class="text-sm font-regular" style="display: none; font-family: 'Noto Sans Thai', 'Segoe UI', sans-serif; margin-left: 8px; min-width: 0; width: 100%;"></div>
                <input type="text" id="message-input" class="text-sm font-regular" placeholder="Type your message..." onkeypress="handleEnterPress(event)" />
                
                <button type="button" class="send-btn" onclick="sendMessage()">
                    <img src="~/images/send_icon.svg" alt="Send" />
                </button>
            </div>  
        </div>
    </div>
    <div id="camera-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: #000000e6; z-index: 9999; flex-direction: column; justify-content: center; align-items: center;">
    
    <video id="camera-stream" autoplay playsinline style="width: 100%; max-width: 600px; max-height: 100vh; object-fit: contain; background: #000; border-radius: 20px;"></video>
    
    <canvas id="camera-canvas" style="display: none;"></canvas>

    <div style="margin-top: 24px; display: flex; gap: 16px;">
        <button type="button" onclick="closeCamera()" style="font-family: 'Noto Sans Thai', 'Segoe UI', sans-serif; padding: 12px 24px; border-radius: 20px; border: none; background: #ef4444; color: white; font-weight: 600; cursor: pointer; box-shadow: rgba(255, 255, 255, 0.05) 0px 4px 12px;">
            Cancle
        </button>
        <button type="button" onclick="takePhoto()" style="font-family: 'Noto Sans Thai', 'Segoe UI', sans-serif; padding: 12px 24px; border-radius: 20px; border: none; background: #9bc7fd; color: white; font-weight: ; cursor: pointer; box-shadow: rgba(255, 255, 255, 0.05) 0px 4px 12px;">
            Capture
        </button>
    </div>
</div>
</body>