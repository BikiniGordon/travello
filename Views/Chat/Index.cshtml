@model IEnumerable<Travello.Models.ChatRoomModel>
@using Microsoft.AspNetCore.Http


@{
    ViewData["Title"] = "Chat";
}
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="~/css/Chat.css" />
<script src="~/js/Chat.js" asp-append-version="true"></script>



<body onload="openChatPage()">
    <div id="current-user-data" data-user-id="@Context.Session.GetString("UserId")" style="display:none;"></div>
    @* ดึง navbar มาด้วย *@
    <div id="chat-header">
        <h id="header-let" class="text-2xl font-regular">Let</h>
        <h id="header-chats" class="text-2xl font-regular ">CHATS !</h>
    </div>
    <div id="chat-container">
        <img id="chat-background-image" src="~/images/chat_img_background.svg" />
        <div id="white-overlay"></div>
        <div id="search-block">
            <img id="search-icon" src="~/images/search_icon.svg" />
            <input type="text" id="search-chat-card" class="text-sm font-semibold " placeholder="Search Chat" />
        </div>
        <div class="chat-list-container">
            <div id="chat-list" class="chat-list">
                @foreach (var chatroom in Model)
                {
                    <div class="chat-card" onclick="openChatRoom('@chatroom.event_id', '@chatroom.chat_name','@chatroom.id','@chatroom.event_location', '@chatroom.event_img_path')">
                        <img class="event-image" src="@chatroom.event_img_path" />
                        <div class="chat-info">
                            <h4 class="chat-info-header text-sm font-semibold">@chatroom.chat_name</h4>
                            <div class="info-row">
                                <img class="locate-icon" src="~/images/locate_icon.svg" />
                                <p class="chat-info-description text-sm font-semibold">@chatroom.event_location</p>
                            </div>
                            <div class="info-row">
                                <img class="date-icon" src="~/images/date_icon.svg" />
                                <p class="chat-info-description text-xs font-semibold">@chatroom.start_date.ToString("d/M/yyyy") - @chatroom.end_date.ToString("d/M/yyyy")</p>
                            </div>
                            <div class="info-row">
                                <img class="path-icon" src="~/images/path_icon.svg" />
                                <p class="chat-info-description text-xs font-semibold">@chatroom.last_message_text@*เวลา message ล่าสุดดึงจาก mesasgemodel*@</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="scroll-blur-overlay"></div>
        </div>



        <div id="empty-room">
            <p class="text-lg font-semibold">Your Messages</p>
            <p class="text-xs font-regular">Select a chat from the list to start messaging.</p>
        </div>



        <div id="setting-room">
            <svg id="setting-back-btn" onclick="backChatRoom()" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            <img id="event-image-setting"/>
            <div id=setting-description>
                <h4 id="setting-event-title" class="text-md font-semibold"></h4>
                <p id="setting-event-status" class="text-xs font-semilight"></p>
                <div id="setting-action-icon">
                    <svg class="action-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell-off-icon lucide-bell-off"><path d="M10.268 21a2 2 0 0 0 3.464 0"/><path d="M17 17H4a1 1 0 0 1-.74-1.673C4.59 13.956 6 12.499 6 8a6 6 0 0 1 .258-1.742"/><path d="m2 2 20 20"/><path d="M8.668 3.01A6 6 0 0 1 18 8c0 2.687.77 4.653 1.707 6.05"/></svg>
                    <img class="action-icon" src="~/images/leave_icon.svg"/>
                </div>
            </div>
            <div id="setting-option">
                <a href="#" onclick="openDetailPage()" id="setting-option-row" class="clickable-row">
                    <h4 class="setting-option-detail text-md font-semibold">Detail</h4>
                    <svg class="action-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right-icon lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <div id="setting-option-row" onclick="openPollRoom()">
                    <h4 class="setting-option-detail text-md font-semibold">Poll</h4>
                    <svg class="action-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right-icon lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
                </div>
                <div id="setting-option-row" onclick="openFileAndLinks()">
                    <h4 class="setting-option-detail text-md font-semibold">Files and Links</h4>
                    <svg class="action-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right-icon lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
                </div>
            </div>
            <div class="setting-media-group">
                <div id="setting-media-grid" class="media-grid">
                    <div class="media-item"></div>
                    <div class="media-item"></div>
                    <div class="media-item"></div>
                    <div class="media-item"></div>
                    <div class="media-item"></div>
                    <div class="media-item"></div>
                </div>
            </div>
        </div>



        <div id="all-poll-room">
            <div id="poll-header-container">
                <svg id="setting-back-btn" onclick="backSettingRoom()" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                <h2 class="text-xl font-semibold">Poll</h2>
            </div>
            <div id="empty-poll">
                <p class="text-lg font-semibold">Trip Polls</p>
                <p class="text-xs font-regular">Create a poll to plan your trip together.</p>
            </div>

            <div id="poll-body"></div>

            <div class="creat-new-poll-container">
                    <button id="create-new-poll-btn" class="text-md font-semibold" onclick="openCreatePoll()">Create a new poll</button>
            </div>
            <template id="poll-card-template">
                <div class="poll-card" onclick="openPollCard()">
                    <h4 class="poll-question text-sm font-semibold"></h4>
                    <div class="poll-info-row">
                        <svg class="trophy" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trophy-icon lucide-trophy"><path d="M10 14.66v1.626a2 2 0 0 1-.976 1.696A5 5 0 0 0 7 21.978"/><path d="M14 14.66v1.626a2 2 0 0 0 .976 1.696A5 5 0 0 1 17 21.978"/><path d="M18 9h1.5a1 1 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M6 9a6 6 0 0 0 12 0V3a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1z"/><path d="M6 9H4.5a1 1 0 0 1 0-5H6"/></svg>
                        <h4 class="number-one text-sm font-regular"></h4>
                        <p class="poll-timeout text-xs font-semibold"></p>
                    </div>
                    <div class="poll-progress-row">
                        <div class="progress-bar-container">
                            <div class="progress-bar-fill"></div>
                        </div>
                        <h4 class="poll-percent text-sm font-semibold"></h4>
                    </div>
                </div>
            </template>
        </div>



        <div id="files-and-links-room">
            <div id="files-links-header-container">
                <svg id="setting-back-btn" onclick="backSettingRoom()" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                <h2 class="text-xl font-semibold">Files and Links</h2>
            </div>
            <div id="empty-poll-files-links">
                <p class="text-lg font-semibold">Files and Links</p>
                <p class="text-xs font-regular">Start send picture in chat.</p>
            </div>

            <div id="files-list-container" style="display: none; flex-direction: column; gap: 12px; overflow-y: auto; max-height: 75vh; padding: 0px 35px 35px 35px">
            </div>
        </div>




        <div id="poll-select-card">
            <div id="poll-header-container">
                <svg id="setting-back-btn" onclick="backToAllPolls()" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                <h2 class="text-xl font-semibold">Poll</h2>
            </div>
            <div id="poll-detail-body">
                <div class="poll-detail-box">
                    <h4 id="detail-poll-question" class="text-lg font-semibold">What will we eat the morning of the trip?</h4>
                    <p id="detail-poll-status" class="poll-timeout text-sm font-semibold">Ended</p>
                    <div id="poll-options-container"></div>
                </div>
            </div>
            <div class="creat-new-poll-container">
                <button id="update-event-btn" class="text-md font-semibold">Update Event</button>
            </div>
            <template id="poll-option-template">
                <div class="poll-option-item">
                    <div class="poll-option-header">
                        <div class="poll-option-left">
                            <div class="poll-radio-circle"></div>
                            <span class="poll-option-text font-semibold"></span>
                        </div>
                        <div class="poll-voters">
                            </div>
                    </div>
                    <div class="progress-bar-container" style="width: 100%;">
                        <div class="progress-bar-fill"></div>
                    </div>
                </div>
            </template>
        </div>



        <div id="create-poll-page">
            <div id="poll-header-container">
                <svg id="setting-back-btn" onclick="backAllPollRoom()" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                <h2 class="text-xl font-semibold">Create Poll</h2>
            </div>

            <div id="create-poll-body">
                <div class="poll-form-group">
                    <h4 class="poll-form-label text-md font-semibold">Poll Question</h4>
                    <input type="text" class="poll-form-input" id="poll-question-input">
                </div>

                <div class="poll-form-group" id="poll-options-group">
                    <h4 class="poll-form-label text-md font-semibold">Option</h4>
                    
                    <div class="poll-option-input-wrapper">
                        <input type="text" class="poll-form-input text-md font-semibold" placeholder="Option 1">
                        <svg class="option-img-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image-plus-icon lucide-image-plus"><path d="M16 5h6"/><path d="M19 2v6"/><path d="M21 11.5V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7.5"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/><circle cx="9" cy="9" r="2"/></svg>
                    </div>
                    
                    <div class="poll-option-input-wrapper">
                        <input type="text" class="poll-form-input text-md font-semibold" placeholder="Option 2">
                        <svg class="option-img-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image-plus-icon lucide-image-plus"><path d="M16 5h6"/><path d="M19 2v6"/><path d="M21 11.5V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7.5"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/><circle cx="9" cy="9" r="2"/></svg>
                    </div>

                    <button id="add-option-btn" type="button">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                        Add Option
                    </button>
                </div>

                <div class="poll-form-group">
                    <h4 class="poll-form-label text-md font-semibold">Set closing time</h4>
                    <div class="datetime-row">
                        <div class="date-input-wrapper">
                            <svg class="calendar-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                            <input type="date" class="poll-form-input date-input">
                        </div>
                        <div class="time-select-wrapper">
                            <select id="poll-hour-select" class="poll-form-input time-select">
                                <option value="" disabled selected>Hour</option>
                            </select>
                            <svg class="dropdown-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down-icon lucide-chevron-down"><path d="m6 9 6 6 6-6"/></svg>
                        </div>
                        <div class="time-select-wrapper">
                            <select id="poll-minute-select" class="poll-form-input time-select">
                                <option value="" disabled selected>Minutes</option>
                            </select>
                            <svg class="dropdown-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down-icon lucide-chevron-down"><path d="m6 9 6 6 6-6"/></svg>
                        </div>
                    </div>
                </div>

                <div class="poll-settings-group">
                    <label class="poll-setting-item text-md font-semibold">
                        <input type="checkbox" class="hidden-checkbox">
                        <span class="custom-radio-circle"></span>
                        Vote for multiple options
                    </label>
                    <label class="poll-setting-item text-md font-semibold">
                        <input type="checkbox" class="hidden-checkbox">
                        <span class="custom-radio-circle"></span>
                        Vote anonymously
                    </label>
                </div>

            </div>
            <div class="creat-new-poll-container">
                <button id="submit-new-poll-btn" class="text-md font-semibold" onclick="submitCreatePoll()">Create Poll</button>
            </div>
        </div>



